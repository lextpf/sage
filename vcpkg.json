{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "seal",
  "version": "1.0.0",
  "description": "AES-256-GCM encryption and credential manager with Qt6 GUI and hardened memory",
  "homepage": "https://github.com/lextpf/seal",
  "license": "MIT",
  "dependencies": [
    "openssl",
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "concurrent",
        "gui",
        "network",
        "opengl",
        "openssl",
        "widgets"
      ]
    },
    "qtdeclarative",
    "qtquickcontrols2",
    "gtest",
    {
      "name": "opencv",
      "default-features": false
    }
  ],
  "overrides": [
    {
      "name": "openssl",
      "version": "3.4.1"
    },
    {
      "name": "opencv",
      "version": "4.10.0"
    }
  ],
  "builtin-baseline": "aa2d37682e3318d93aef87efa7b0e88e81cd3d59"
}
